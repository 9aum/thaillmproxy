# Copy this file to .env and fill in your values
# cp .env.example .env

# Required
THAILLM_API_KEY=your_api_key_here

# Optional (defaults shown)
THAILLM_BASE_URL=http://thaillm.or.th/api/v1
PROXY_HOST=127.0.0.1
PROXY_PORT=4000
STRIP_THINK=false

# Rate limits (stay slightly below ThaiLLM official limits)
MAX_PER_SECOND=4
MAX_PER_MINUTE=180
MAX_RETRY_ON_429=3
